oauth_client_id     = ""
oauth_client_secret = ""
billing_account_id  = ""
notification_email  = ""

# Cloudflare 連携を使う場合のみ uncomment して値を入れる。
# 未指定 (= null) なら cloudflare_reader モジュールが count = 0 で無効化される。
# 空文字 "" は不可: var.cloudflare_account_id == null 判定をパスせず module が有効化され、
# Cloudflare API 呼び出しが失敗する。
# cloudflare_account_id = "<your-cloudflare-account-id>"
# cloudflare_api_token  = "<your-cloudflare-api-token>"
