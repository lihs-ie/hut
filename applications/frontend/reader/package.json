{
  "name": "@hut/reader",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:cloudflare": "bash scripts/build-cloudflare.sh",
    "preview:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare preview",
    "deploy:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare deploy",
    "upload:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hut/shared": "workspace:*",
    "@opennextjs/cloudflare": "^1.19.1",
    "firebase": "^12.11.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "nuqs": "^2.8.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@lihs-ie/forger-ts": "^0.0.2",
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@types/mdx": "^2.0.13",
    "babel-plugin-react-compiler": "^1.0.0",
    "remark-breaks": "^4.0.0",
    "wrangler": "^4.83.0"
  }
}
