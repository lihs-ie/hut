    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@lihs-ie/forger-ts": "^0.0.2",
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^16.2.3",
